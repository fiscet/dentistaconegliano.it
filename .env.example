# Copia questo file in .env.local e compila i valori reali (NON committare .env.local).

# --- Sanity ---
NEXT_PUBLIC_SANITY_PROJECT_ID="wqblxiv7"
NEXT_PUBLIC_SANITY_DATASET="development"
SANITY_API_READ_TOKEN=""
SANITY_API_WRITE_TOKEN=""

# --- Form contatti: SMTP Keliweb (nodemailer) ---
# host/porta del server di posta Keliweb; porta 465 = SSL, 587 = STARTTLS
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""            # es. info@dentistaconegliano.it
SMTP_PASSWORD=""
CONTACT_FROM=""         # mittente (di solito uguale a SMTP_USER)
CONTACT_TO=""           # dove lo studio riceve le richieste

# --- Arcjet (anti-spam/bot del form) ---
# Chiave da https://app.arcjet.com (free tier). Senza chiave il form funziona
# comunque, ma senza protezione.
ARCJET_KEY=""
ARCJET_ENV="development"
